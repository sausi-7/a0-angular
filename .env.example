# Copy this file to `.env` and fill in values.
# The `.env` file is gitignored.

# Per-deployment secret used to encrypt BYOK API keys at rest.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
A0_SECRET_KEY=change-me-to-a-random-32-byte-secret

# Optional: default provider keys the platform can fall back to in dev.
# In production, users supply their own keys via the settings UI.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
